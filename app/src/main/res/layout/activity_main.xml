<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/themed_background_blur">


    <FrameLayout
        android:id="@+id/tutorialOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:elevation="100dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/swipeTutorial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:padding="24dp">

            <TextView
                android:id="@+id/swipeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/swipe_tutorial"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:gravity="center"/>

            <ImageView
                android:id="@+id/swipeArrow"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/swipeimage"
                android:layout_gravity="center"/>
        </LinearLayout>

        <!-- Click Tutorial -->
        <LinearLayout
            android:id="@+id/clickTutorial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/click_tutorial"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:gravity="center"/>

            <ImageView
                android:id="@+id/clickArrow"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/clickimage"
                android:layout_marginBottom="20dp"
                android:layout_gravity="center"/>
        </LinearLayout>

    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageUpCard"
        android:layout_width="0dp"
        android:elevation="10dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.9"
        app:layout_constraintHeight_percent="0.49"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:strokeWidth="4dp"
        app:strokeColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp">

        <!-- Card Front -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_front_up"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/yumly_sand">

            <TextView
                android:id="@+id/zzTop"
                android:layout_width="140dp"
                android:layout_height="30dp"
                android:background="@drawable/time_button_long"
                android:gravity="center"
                android:paddingStart="30dp"
                android:paddingBottom="1dp"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@+id/imageUp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/dishNameTop"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="5dp"
                android:layout_marginTop="2dp"
                tools:text="120 Min." />


            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageUp"
                android:layout_width="0dp"
                android:layout_height="0dp"

                app:layout_constraintBottom_toTopOf="@id/dishNameTop"

                android:background="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintDimensionRatio="W,1:1"
                android:scaleType="centerCrop"
                android:adjustViewBounds="false"
                app:shapeAppearanceOverlay="@style/abgerundet" />

            <TextView
                android:id="@+id/dishNameTop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center_horizontal"
                app:layout_constraintTop_toBottomOf="@+id/imageUp"
                app:layout_constraintBottom_toBottomOf="parent"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:focusable="true"
                android:focusableInTouchMode="true"
                app:layout_constraintWidth_percent="0.50"
                android:layout_marginStart="10dp"
                app:layout_constraintEnd_toStartOf="@id/zzTop"
                app:layout_constraintStart_toStartOf="parent"
                android:paddingBottom="4dp"
                tools:text="Platzhalterfsdnfjdjghdfjkgbkjfdhgkjdhfjkgjdkfhgjkdfhgh" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Card Back -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_back_up"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/yumly_sand"
            android:visibility="gone">

            <GridLayout
                android:id="@+id/attribute_grid_up"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="16dp"
                android:columnCount="3"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/recipe_website_button_up"/>

            <Button
                android:id="@+id/recipe_website_button_up"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recipe_website"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="16dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageDownCard"
        android:elevation="10dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.9"
        app:layout_constraintHeight_percent="0.49"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:strokeWidth="4dp"
        app:strokeColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp">

        <!-- Card Front -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_front_down"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/yumly_sand">

            <TextView
                android:id="@+id/zzDown"
                android:layout_width="145dp"
                android:layout_height="30dp"
                android:background="@drawable/time_button_long"
                android:gravity="center"
                android:paddingStart="30dp"
                android:paddingBottom="1dp"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/imageDown"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/dishNameDown"

                android:layout_marginTop="5dp"
                android:layout_marginBottom="2dp"
                tools:text="120 Min." />


            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageDown"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@id/dishNameDown"

                app:layout_constraintDimensionRatio="W,1:1"
                android:background="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:shapeAppearanceOverlay="@style/abgerundet" />

            <TextView
                android:id="@+id/dishNameDown"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center_horizontal"
                app:layout_constraintBottom_toTopOf="@id/imageDown"
                app:layout_constraintTop_toTopOf="parent"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:focusable="true"
                android:focusableInTouchMode="true"
                app:layout_constraintWidth_percent="0.50"
                android:paddingTop="4dp"
                android:layout_marginEnd="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/zzDown"
                tools:text="Platzhalter" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Card Back -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_back_down"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/yumly_sand"
            android:visibility="gone">

            <GridLayout
                android:id="@+id/attribute_grid_down"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="16dp"
                android:columnCount="3"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/recipe_website_button_down"/>

            <Button
                android:id="@+id/recipe_website_button_down"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recipe_website"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="16dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>